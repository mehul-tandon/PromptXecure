# ============================================================
# PromptXecure — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Application ─────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
ENABLE_DOCS=true

# ── Network ──────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
CORS_ORIGINS=http://localhost

# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=promptxecure
POSTGRES_PASSWORD=changeme_strong_password_here
POSTGRES_DB=promptxecure

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis_password_here

# ── LLM Keys (add at least one) ──────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...

# ── Langfuse (LLM Observability) ──────────────────────────────
# Get keys from Langfuse after first login at http://localhost/langfuse
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
LANGFUSE_SALT=generate-with-openssl-rand-base64-16

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme_grafana_password

# ── Detection Settings ────────────────────────────────────────
RISK_THRESHOLD_SUSPICIOUS=0.3
RISK_THRESHOLD_MALICIOUS=0.7
ML_ENABLED=true
SHADOW_LLM_ENABLED=false
SHADOW_LLM_MODEL=ollama/llama3
OUTPUT_VALIDATION_ENABLED=true
