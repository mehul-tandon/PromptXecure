# PromptXecure — Main environment config
# Copy to .env and fill in your values

# App
ENVIRONMENT=development
DEBUG=true
ENABLE_DOCS=true

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://promptxecure:secret@localhost:5432/promptxecure

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM API Keys (fill in the ones you need)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
LITELLM_DEFAULT_MODEL=gpt-4o-mini
LLM_TIMEOUT=30
LLM_MAX_TOKENS=2048

# Detection
RULES_PATH=../promptxecure-rules/rules/
ML_MODEL_PATH=../promptxecure-core/data/model/
ML_ENABLED=true
SHADOW_LLM_ENABLED=false
SHADOW_LLM_MODEL=ollama/llama3
OUTPUT_VALIDATION_ENABLED=true

# Thresholds
RISK_THRESHOLD_SUSPICIOUS=0.3
RISK_THRESHOLD_MALICIOUS=0.7

# Langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# Security
API_KEY=
FORCE_HTTPS=false
MAX_REQUEST_SIZE=1048576
